HTTP_PORT=7475

# Local dev:
# POSTGRES_URL=postgres://postgres:postgres@localhost:5432/ai_chat?sslmode=disable
#
# VPS deploy (app container attaches to ai-chat_default network,
# postgres container is reachable as host `db`):
# POSTGRES_URL=postgres://aichat:<password>@db:5432/aichat?sslmode=disable
POSTGRES_URL=postgres://aichat:CHANGE_ME@db:5432/aichat?sslmode=disable

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Separate API key for image generation (gpt-image-1).
# If omitted, falls back to OPENAI_API_KEY.
GPT_IMAGE_1=sk-...
OPENAI_IMAGE_MODEL=gpt-image-1
